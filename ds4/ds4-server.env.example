# Runtime arguments for ds4-server, passed verbatim (word-split) by systemd.
# Copy to /etc/ds4/ds4-server.env and edit, then:
#   sudo systemctl restart ds4-server
#
# host 127.0.0.1 keeps the API local-only. Change to 0.0.0.0 to expose on the
# LAN (then firewall the port; the server has no auth). The model path is the
# stable alias that install.sh creates in /var/lib/ds4/models.

DS4_SERVER_ARGS="--host 127.0.0.1 --port 8000 --ctx 100000 -m /var/lib/ds4/models/ds4flash.gguf --kv-disk-dir /var/lib/ds4/kv --kv-disk-space-mb 8192"

# Optional speculative decoding: append the MTP draft model that install.sh
# relocated, e.g.
#   --mtp /var/lib/ds4/models/DeepSeek-V4-Flash-MTP-Q4K-Q8_0-F32.gguf --mtp-draft 2
