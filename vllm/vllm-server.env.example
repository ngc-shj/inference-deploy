# Runtime configuration for vllm-server (NGC container, run via systemd).
# Copy to /etc/vllm/vllm-server.env and edit, then:
#   sudo systemctl restart vllm-server
#
# Unlike llama.cpp/ds4 (bare-metal binaries), vLLM runs from the NVIDIA NGC
# container nvcr.io/nvidia/vllm, which is pre-built for DGX Spark / GB10
# (aarch64, sm_121) — no source build. The systemd unit runs `docker run` with
# the variables below; the binary lives inside the image.
#
# vLLM serves ONE model per process (no llama.cpp-style router). To serve a
# second model, run a second instance on another port.

# --- container image ----------------------------------------------------------
# Pick a tag from the NGC catalog. Tags are monthly: YY.MM-py3 (e.g. 26.05-py3).
#   https://catalog.ngc.nvidia.com/orgs/nvidia/containers/vllm/tags
# Pin an explicit tag (NOT :latest) so restarts are reproducible. DGX Spark / GB10
# support landed in 26.01-py3; use that or newer on this box.
VLLM_IMAGE="nvcr.io/nvidia/vllm:26.05-py3"

# --- model --------------------------------------------------------------------
# Hugging Face model handle served on this instance. Weights download to the
# cache below on first start (large; expect a wait — watch journald).
VLLM_MODEL="openai/gpt-oss-20b"

# --- network ------------------------------------------------------------------
# host 127.0.0.1 keeps the API local-only. Change to 0.0.0.0 to expose on the
# LAN (then firewall the port; vLLM has no auth unless --api-key is set).
VLLM_HOST="127.0.0.1"
VLLM_PORT="8000"

# --- HF auth (optional) -------------------------------------------------------
# Required only for gated/private repos (e.g. meta-llama/*). Leave empty for
# open models like gpt-oss-20b. Keep this file 0640 root:root if you set it —
# it is a secret. install.sh installs it 0640.
HF_TOKEN=""

# --- vllm serve flags ---------------------------------------------------------
# Appended verbatim after `vllm serve $VLLM_MODEL --host ... --port ...`.
#
# --gpu-memory-utilization is a FRACTION OF TOTAL device memory, reserved up
# front. This is an ON-DEMAND comparison engine: the unit's Conflicts= stops
# llama-server when vLLM starts, so vLLM has the (near-)full 128GB unified pool
# and this can run high. 0.60 ≈ 73GB — plenty for gpt-oss-20b. If you ever run
# vLLM and llama-server side by side, drop this hard (0.20 ≈ 25GB) or it OOMs.
# Verify the footprint with:  nvidia-smi ;  free -g
VLLM_SERVE_ARGS="--gpu-memory-utilization 0.60 --max-model-len 32768"

# Examples for other models:
#   Qwen safetensors (vLLM serves HF format directly, no GGUF):
#     VLLM_MODEL="Qwen/Qwen3-32B"
#     VLLM_SERVE_ARGS="--gpu-memory-utilization 0.60 --max-model-len 32768"
#   Pre-quantized FP8 weights (smaller footprint per param):
#     VLLM_SERVE_ARGS="--quantization fp8 --gpu-memory-utilization 0.50"
