# Runtime arguments for llama-server, passed verbatim (word-split) by systemd.
# Copy to /etc/llama/llama-server.env and edit, then:
#   sudo systemctl restart llama-server
#
# Default config is ROUTER MODE: no model on the command line, so the router
# forwards each request to the right model instance based on the OpenAI "model"
# field. Clients switch models without restarting the server. The args here are
# GLOBAL defaults inherited by every model instance; per-model settings (context
# size, speculative decoding, ...) live in /etc/llama/models.ini.
#
# host 127.0.0.1 keeps the API local-only. Change to 0.0.0.0 to expose on the
# LAN (then firewall the port). -ngl 999 offloads all layers to the GB10 GPU and
# -fa on enables Flash Attention — both are safe to apply to every model.
# --models-max caps how many models stay resident at once (others are unloaded
# on demand). --models-preset points at the per-model INI.

# --- Router mode (current production config) ----------------------------------
LLAMA_SERVER_ARGS="--host 127.0.0.1 --port 8080 -ngl 999 -fa on --models-max 3 --models-preset /etc/llama/models.ini"

# --- Single-model mode --------------------------------------------------------
# Pin one model on the command line; the request "model" field is then ignored.
#LLAMA_SERVER_ARGS="--host 127.0.0.1 --port 8080 -hf unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_XL -ngl 999 -c 65536 -fa on -np 1 --spec-type draft-mtp --spec-draft-n-max 2"

# --- Local GGUF (single-model) ------------------------------------------------
#LLAMA_SERVER_ARGS="--host 127.0.0.1 --port 8080 -m /var/lib/llama/models/your-model.gguf -ngl 999 -c 8192 -fa on"
