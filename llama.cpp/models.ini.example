; Per-model presets for llama-server router mode (--models-preset).
; Copy to /etc/llama/models.ini and edit, then:
;   sudo systemctl restart llama-server
;
; Section name = the model ID the router exposes (what clients send in the
; OpenAI "model" field). For -hf models it is "<repo>:<tag>". Confirm the exact
; ID the server advertises with:
;   curl -s localhost:8080/v1/models | jq -r '.data[].id'
;
; Keys are llama-server flags without leading dashes (long form, short form, or
; the LLAMA_ARG_* env name): "--n-gpu-layers 8" -> "n-gpu-layers = 8" or "ngl = 8".
; Precedence: CLI args (llama-server.env) > model section > [*] global section.
; host / port / api-key / -hf / alias are router-controlled and ignored here.
;
; Sampling (temperature / top_p / top_k / penalties) is NOT set here — it is a
; per-request, client-side choice, not a load-time flag. The recommended values
; per model are noted as comments on each section below for reference; pass them
; in the OpenAI request body. See EVALUATIONS.md for sources and the note that
; throughput is independent of sampling.
;
; Models must be in the cache before the router can serve them. Download once:
;   sudo -u llama LLAMA_CACHE=/var/lib/llama/cache /opt/llama/bin/llama-server \
;       -hf unsloth/gpt-oss-20b-GGUF:F16 -ngl 0
; wait for "model loaded", Ctrl-C, then restart llama-server.

version = 1

; Global defaults shared by all models (a section may override any key).
[*]
c = 8192

; The MTP speculative-decoding flags below are specific to this model (they need
; its multi-token-prediction head) — keep them per-section, NOT in [*], so a
; non-MTP model like Qwopus below is safe.

; --- Qwen3.6-35B-A3B UD-Q4_K_XL (~20GB) — big model, efficient quant -----------
; Runs at full native 262144 context (no YaRN). KV ~26GB at this length; the
; 3-model resident set then totals ~93GB, within the 128GB box. If memory gets
; tight, add `cache-type-k = q8_0` / `cache-type-v = q8_0` here to halve KV.
; NOTE: the cached file is Qwen3.6-...-UD-Q4_K_XL.gguf, but the router DROPS the
; Unsloth "UD-" prefix when deriving the model ID, advertising it as :Q4_K_XL.
; The section name must match that advertised ID (NOT :UD-Q4_K_XL) or these
; settings attach to nothing. Always verify: curl -s localhost:8080/v1/models.
; Client-side sampling (send in the request, not here): instruct/non-thinking
;   temp=0.7 top_p=0.8 top_k=20 min_p=0; thinking temp=0.6 top_p=0.95 top_k=20
;   min_p=0 (Qwen3-family generation_config defaults). Add presence_penalty=1.5
;   for long sessions to curb repetition.
[unsloth/Qwen3.6-35B-A3B-MTP-GGUF:Q4_K_XL]
c = 262144
np = 1
spec-type = draft-mtp
spec-draft-n-max = 2
load-on-startup = true

; Qwopus3.5-9B-v3: a plain (non-MTP) 9B model — NO spec-type here. It inherits
; c = 8192 from [*]. The repo also ships an mmproj for vision; to enable it add
;   mmproj = /var/lib/llama/cache/<mmproj path>
; (or convert/place it manually). Text-only by default.

; --- Qwopus3.5-9B-v3 Q8 (Q8_0, ~9.5GB) — near-lossless, the sane default -------
; Trained context 262144, so 131072 is native. Dense (full attention all layers)
; makes its KV the heaviest of the three (~19GB at 131072) despite being 9B; drop
; this lower, or add -ctk/-ctv q8_0, if you need the headroom.
; Sampling: a Qwen3.5 finetune — same Qwen3-family values as the 35B above:
;   instruct/non-thinking temp=0.7 top_p=0.8 top_k=20 min_p=0;
;   thinking temp=0.6 top_p=0.95 top_k=20 min_p=0. presence_penalty=1.5 for
;   long sessions to curb repetition. (The finetune card may override these.)
[Jackrong/Qwopus3.5-9B-v3-GGUF:Q8_0]
c = 131072

; --- Qwopus3.5-9B-v3 Q4 (Q4_K_M, ~5.6GB) — enable only to compare quant loss ---
;[Jackrong/Qwopus3.5-9B-v3-GGUF:Q4_K_M]

; gpt-oss-20b: OpenAI MoE, natively MXFP4 — F16 keeps the experts at MXFP4 (so
; it's only ~14GB, not ~26GB) and is effectively full quality; lower quants only
; shrink the small dense part. NOT MTP, so no spec-type. The "gpt-oss" / Harmony
; chat template is built in. Reasoning effort is set client-side, not here.
; Sampling: recommended temp=1.0 with top_p=1.0 (or 0.95) — tune one, not both.
; Control verbosity via the reasoning-effort field (low/medium/high), not temp.

; --- gpt-oss-20b F16 (~13.8GB) — non-Qwen family, adjustable reasoning ---------
; Native 131072 context; alternating sliding-window attention keeps long-context
; KV cheap (roughly half a full-attention model's).
[unsloth/gpt-oss-20b-GGUF:F16]
c = 131072

; Qwopus3.6-35B-A3B-Coder-MTP: an optional coding-first model. Same
; Qwen3.6-35B-A3B base as the resident model above + an embedded MTP head, so
; `spec-type = draft-mtp` works with the flag alone (no sidecar). Apache-2.0
; agentic-coding finetune (Jackrong). Measured fastest local coder on GB10 —
; 95-100 tok/s no-think, beating the resident 35B-A3B; see EVALUATIONS.md and
; CODING_MODEL_STUDY.md. Not loaded on startup here; point opencode/aider at it.

; --- Qwopus3.6-35B-A3B-Coder-MTP Q4_K_M (~21.7GB) — coding first pick ----------
; Trained ctx 262144 (same as the resident 35B-A3B); hybrid linear attn keeps KV
; light, so full native fits in the 128GB pool. Halve KV with cache-type q8_0 if
; memory gets tight.
; MUST be run thinking-off: send `chat_template_kwargs:{enable_thinking:false}`
; in the request, or it over-thinks and can hit the token cap with empty code.
; Sampling (client-side): Qwen3-family instruct temp=0.7 top_p=0.8 top_k=20
; min_p=0. The repo also ships an mmproj (vision) — text-only unless you add
;   mmproj = /var/lib/llama/cache/<mmproj path>
[Jackrong/Qwopus3.6-35B-A3B-Coder-MTP-GGUF:Q4_K_M]
c = 262144
np = 1
spec-type = draft-mtp
spec-draft-n-max = 2
